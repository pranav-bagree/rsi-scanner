<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ title }} — {{ run_ts_human_pt }}</title>
<style>
  :root {
    --bg: #0a0e1a;
    --bg-card: #131826;
    --bg-card-soft: #1a2030;
    --border: rgba(255,255,255,0.08);
    --border-strong: rgba(255,255,255,0.16);
    --text: #e6edf3;
    --text-muted: #8b95a7;
    --text-dim: #5d6877;
    --accent: #7c8aff;

    /* Sell semantics (overbought): red signal, orange watch */
    --sell: #f85149;
    --sell-soft: rgba(248,81,73,0.12);
    --sell-light: #ff8a3d;
    --sell-light-soft: rgba(255,138,61,0.14);

    /* Buy semantics (oversold): green signal, soft green watch */
    --buy: #3fb950;
    --buy-soft: rgba(63,185,80,0.14);
    --buy-light: #6fd189;
    --buy-light-soft: rgba(111,209,137,0.12);

    /* Legacy aliases — kept so change-pos/change-neg in the scan table keep their
       intuitive meaning (green = up, red = down) independent of RSI semantics. */
    --alert: var(--sell);
    --ok: var(--buy);
  }
  * { box-sizing: border-box; }
  html, body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Segoe UI", Roboto, "Helvetica Neue", sans-serif;
    font-size: 15px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
  }
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }
  code, .mono { font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace; font-size: 13px; }

  .wrap { max-width: 1200px; margin: 0 auto; padding: 48px 28px 96px; }

  header.page {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 32px; flex-wrap: wrap; margin-bottom: 8px;
  }
  header.page h1 {
    font-size: 28px; margin: 0; font-weight: 600; letter-spacing: -0.01em;
  }
  header.page .meta { color: var(--text-muted); font-size: 13px; }
  header.page .meta .mono { color: var(--text); }

  .summary {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px;
    margin: 28px 0 36px;
  }
  .summary .stat {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 10px; padding: 16px 18px;
  }
  .summary .stat .label {
    color: var(--text-muted); font-size: 12px; text-transform: uppercase;
    letter-spacing: 0.05em; margin-bottom: 6px;
  }
  .summary .stat .value { font-size: 26px; font-weight: 600; letter-spacing: -0.01em; }
  .summary .stat.buy .value { color: var(--buy); }
  .summary .stat.buy-light .value { color: var(--buy-light); }
  .summary .stat.sell .value { color: var(--sell); }
  .summary .stat.sell-light .value { color: var(--sell-light); }

  section { margin-top: 40px; }
  section h2 {
    font-size: 18px; font-weight: 600; letter-spacing: -0.01em;
    margin: 0 0 16px; display: flex; align-items: center; gap: 10px;
  }
  section h2 .count {
    font-size: 12px; font-weight: 500; padding: 2px 8px; border-radius: 999px;
    background: var(--bg-card-soft); color: var(--text-muted);
  }
  section h2 .count.buy { background: var(--buy-soft); color: var(--buy); }
  section h2 .count.buy-light { background: var(--buy-light-soft); color: var(--buy-light); }
  section h2 .count.sell { background: var(--sell-soft); color: var(--sell); }
  section h2 .count.sell-light { background: var(--sell-light-soft); color: var(--sell-light); }

  /* Hit card (oversold, with full analysis) */
  .hit {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 14px; padding: 28px; margin-bottom: 20px;
    border-left: 3px solid var(--buy);
  }
  .hit > .header {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 24px; flex-wrap: wrap; margin-bottom: 18px;
  }
  .hit .title { display: flex; align-items: baseline; gap: 14px; flex-wrap: wrap; }
  .hit .ticker { font-size: 28px; font-weight: 700; letter-spacing: -0.02em; }
  .hit .company { color: var(--text-muted); font-size: 15px; }
  .hit .sector-tag {
    font-size: 11px; padding: 3px 10px; border-radius: 999px;
    background: var(--bg-card-soft); color: var(--text-muted);
    text-transform: uppercase; letter-spacing: 0.04em;
  }
  .hit .key-stats { display: flex; gap: 24px; flex-wrap: wrap; }
  .hit .key-stats .ks { text-align: right; }
  .hit .key-stats .ks .label { font-size: 11px; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.05em; }
  .hit .key-stats .ks .value { font-size: 22px; font-weight: 600; letter-spacing: -0.01em; }
  .hit .key-stats .ks .value.rsi-oversold { color: var(--buy); }
  .hit .key-stats .ks .value.move-neg { color: var(--sell); }
  .hit .key-stats .ks .sub { font-size: 12px; color: var(--text-muted); margin-top: 2px; }

  .hit .analysis-section {
    margin-top: 20px; padding-top: 20px;
    border-top: 1px solid var(--border);
  }
  .hit .analysis-section h3 {
    font-size: 13px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--text-muted); margin: 0 0 14px;
  }
  .hit .analysis-section .body {
    font-size: 14.5px; line-height: 1.65;
  }
  .hit .analysis-section .body p { margin: 0 0 12px; }
  .hit .analysis-section .body p:last-child { margin-bottom: 0; }
  .hit .analysis-section .body h2 {
    font-size: 14px; font-weight: 600; margin: 18px 0 8px;
    color: var(--text); text-transform: none; letter-spacing: 0;
  }
  .hit .analysis-section .body h2:first-child { margin-top: 0; }
  .hit .analysis-section .body ul { margin: 8px 0 12px; padding-left: 20px; }
  .hit .analysis-section .body li { margin-bottom: 4px; }
  .hit .analysis-section .body code { background: var(--bg-card-soft); padding: 1px 6px; border-radius: 4px; }

  .citations {
    margin-top: 14px; padding-top: 12px; border-top: 1px dashed var(--border);
    font-size: 12px; color: var(--text-muted);
  }
  .citations strong { color: var(--text-muted); font-weight: 500; }
  .citations a { display: inline-block; margin-right: 14px; }

  .analysis-skipped {
    font-style: italic; color: var(--text-muted); font-size: 13px;
  }

  /* Watchlist (approaching oversold / approaching overbought) */
  .watch-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 10px;
  }
  .watch-card {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 10px; padding: 14px 16px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .watch-card.approaching-oversold { border-left: 3px solid var(--buy-light); }
  .watch-card.approaching-overbought { border-left: 3px solid var(--sell-light); }
  .watch-card .lhs .ticker { font-weight: 600; font-size: 15px; }
  .watch-card .lhs .company { font-size: 12px; color: var(--text-muted); }
  .watch-card .rhs { text-align: right; }
  .watch-card .rsi-val { font-size: 18px; font-weight: 600; }
  .watch-card.approaching-oversold .rsi-val { color: var(--buy-light); }
  .watch-card.approaching-overbought .rsi-val { color: var(--sell-light); }
  .watch-card .price { font-size: 12px; color: var(--text-muted); margin-top: 1px; }

  /* Compact overbought signal card (no analysis) */
  .ob-grid {
    display: grid; grid-template-columns: 1fr; gap: 10px;
  }
  .ob-card {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 10px; padding: 14px 16px;
    border-left: 3px solid var(--sell);
    display: grid; grid-template-columns: 1fr auto; gap: 16px;
    align-items: center;
  }
  .ob-card .lhs .ticker { font-weight: 700; font-size: 18px; letter-spacing: -0.01em; }
  .ob-card .lhs .company { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
  .ob-card .lhs .sector-tag {
    display: inline-block;
    font-size: 10.5px; padding: 2px 8px; border-radius: 999px;
    background: var(--bg-card-soft); color: var(--text-muted);
    text-transform: uppercase; letter-spacing: 0.04em;
    margin-top: 6px;
  }
  .ob-card .rhs { text-align: right; }
  .ob-card .rsi-val { font-size: 20px; font-weight: 600; letter-spacing: -0.01em; color: var(--sell); }
  .ob-card .price { font-size: 13px; color: var(--text-muted); margin-top: 2px; }
  .ob-card .sub { font-size: 11px; color: var(--text-dim); margin-top: 2px; }
  .ob-card .sub.move-pos { color: var(--buy); }

  /* Side-by-side layout for the overbought + approaching-overbought pair */
  .side-by-side {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    align-items: start;
  }
  .side-by-side .col h2 { margin-top: 0; }
  @media (max-width: 880px) {
    .side-by-side { grid-template-columns: 1fr; }
  }

  /* Full scan table */
  details.full-scan { margin-top: 16px; }
  details.full-scan > summary {
    cursor: pointer; padding: 12px 16px;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 10px; user-select: none;
    color: var(--text-muted); font-size: 14px;
    display: flex; align-items: center;
  }
  details.full-scan[open] > summary { border-bottom-left-radius: 0; border-bottom-right-radius: 0; }
  .scan-search {
    background: var(--bg-card);
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
    padding: 12px 14px;
    display: flex; align-items: center; gap: 10px;
  }
  .scan-search input {
    flex: 1;
    background: var(--bg-card-soft);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    padding: 9px 12px;
    font-size: 13.5px;
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .scan-search input:focus { border-color: var(--accent); background: var(--bg-card); }
  .scan-search input::placeholder { color: var(--text-dim); }
  .scan-search .visible-count {
    color: var(--text-muted); font-size: 12px; white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
  details.full-scan table {
    width: 100%; border-collapse: collapse;
    background: var(--bg-card); border: 1px solid var(--border); border-top: none;
    border-bottom-left-radius: 10px; border-bottom-right-radius: 10px;
    overflow: hidden;
  }
  details.full-scan .empty-search {
    background: var(--bg-card); border: 1px solid var(--border); border-top: none;
    border-bottom-left-radius: 10px; border-bottom-right-radius: 10px;
    padding: 24px; text-align: center; color: var(--text-muted); font-size: 13px;
    display: none;
  }
  details.full-scan th, details.full-scan td {
    padding: 10px 14px; text-align: left; font-size: 13px;
    border-bottom: 1px solid var(--border);
  }
  details.full-scan tr:last-child td { border-bottom: none; }
  details.full-scan th {
    color: var(--text-muted); font-weight: 500;
    text-transform: uppercase; letter-spacing: 0.05em; font-size: 11px;
    background: var(--bg-card-soft);
  }
  details.full-scan th.sortable {
    cursor: pointer; user-select: none;
    transition: color 0.12s, background 0.12s;
  }
  details.full-scan th.sortable:hover { color: var(--text); background: var(--bg-card); }
  details.full-scan th .sort-arrow {
    display: inline-block; margin-left: 4px; font-size: 10px;
    color: var(--text-dim); transition: color 0.12s;
    font-variant-numeric: tabular-nums;
  }
  details.full-scan th.sort-asc .sort-arrow,
  details.full-scan th.sort-desc .sort-arrow { color: var(--accent); }
  details.full-scan th.sort-asc, details.full-scan th.sort-desc { color: var(--text); }
  details.full-scan td.numeric { text-align: right; font-variant-numeric: tabular-nums; }
  details.full-scan th.numeric { text-align: right; }
  details.full-scan td.ticker { font-weight: 600; }
  details.full-scan td.sector { color: var(--text-muted); font-size: 12px; }
  details.full-scan tr.row-oversold td { background: var(--buy-soft); }
  details.full-scan tr.row-watch td { background: var(--buy-light-soft); }
  details.full-scan tr.row-overbought td { background: var(--sell-soft); }
  details.full-scan tr.row-watch-overbought td { background: var(--sell-light-soft); }
  details.full-scan tr.row-error td { color: var(--text-dim); font-style: italic; }
  details.full-scan .rsi-cell.oversold { color: var(--buy); font-weight: 600; }
  details.full-scan .rsi-cell.watch { color: var(--buy-light); font-weight: 500; }
  details.full-scan .rsi-cell.overbought { color: var(--sell); font-weight: 600; }
  details.full-scan .rsi-cell.watch-overbought { color: var(--sell-light); font-weight: 500; }
  details.full-scan .change-pos { color: var(--buy); }
  details.full-scan .change-neg { color: var(--sell); }

  /* Collapsible fundamentals columns */
  .fund-col { display: none; }
  .show-fundamentals .fund-col { display: table-cell; }
  .toggle-fund-btn {
    margin-left: auto;
    font-size: 12px;
    padding: 3px 10px;
    border-radius: 6px;
    border: 1px solid var(--border-strong);
    background: var(--bg-card-soft);
    color: var(--text-muted);
    cursor: pointer;
    white-space: nowrap;
  }
  .toggle-fund-btn:hover { color: var(--text); border-color: var(--accent); }

  .empty-state {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 12px; padding: 36px; text-align: center;
    color: var(--text-muted);
  }
  .empty-state .emoji-free-mark { font-size: 28px; font-weight: 600; color: var(--buy); margin-bottom: 6px; letter-spacing: -0.01em; }

  .empty-state-compact {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 10px; padding: 18px; text-align: center;
    color: var(--text-muted); font-size: 13px;
  }

  footer.page {
    margin-top: 64px; padding-top: 24px;
    border-top: 1px solid var(--border);
    color: var(--text-dim); font-size: 12px;
    display: flex; justify-content: space-between; gap: 12px; flex-wrap: wrap;
  }
</style>
</head>
<body>
<div class="wrap">

  <header class="page">
    <div>
      <h1>{{ title }}</h1>
      <div class="meta">
        Scan run <span class="mono">{{ run_ts_human_pt }}</span> ·
        <span class="mono">{{ universe_size }}</span> tickers ·
        last closed 4h bar: <span class="mono">{{ latest_bar_human }}</span>
        {% if has_live %}·
          live (in-progress) bar: <span class="mono">{{ live_bar_human }}</span>
        {% endif %}
      </div>
    </div>
  </header>

  <div class="summary">
    <div class="stat {% if hits|length %}buy{% endif %}">
      <div class="label">Oversold (RSI &lt; {{ oversold_threshold }})</div>
      <div class="value">{{ hits|length }}</div>
    </div>
    <div class="stat {% if overbought_hits|length %}sell{% endif %}">
      <div class="label">Overbought (RSI &gt; {{ overbought_threshold }})</div>
      <div class="value">{{ overbought_hits|length }}</div>
    </div>
    <div class="stat">
      <div class="label">Universe</div>
      <div class="value">{{ universe_size }}</div>
    </div>
    <div class="stat">
      <div class="label">Median RSI</div>
      <div class="value">{{ "%.1f"|format(median_rsi) if median_rsi is not none else "—" }}</div>
    </div>
  </div>

  {% if hits %}
    <section>
      <h2>Oversold signals <span class="count buy">{{ hits|length }}</span></h2>
      {% for h in hits %}
        <div class="hit">
          <div class="header">
            <div class="title">
              <div class="ticker">{{ h.ticker }}</div>
              <div class="company">{{ h.company }}</div>
              <div class="sector-tag">{{ h.sector }}</div>
            </div>
            <div class="key-stats">
              <div class="ks">
                <div class="label">Price</div>
                <div class="value">${{ "%.2f"|format(h.price) }}</div>
                <div class="sub">{{ h.bar_human }}</div>
              </div>
              <div class="ks">
                <div class="label">RSI(14)</div>
                <div class="value rsi-oversold">{{ "%.2f"|format(h.rsi) }}</div>
                <div class="sub">threshold &lt; {{ oversold_threshold }}</div>
              </div>
              <div class="ks">
                <div class="label">5-bar move</div>
                <div class="value {% if h.move_5bar_pct < 0 %}move-neg{% endif %}">{{ "%+.1f"|format(h.move_5bar_pct) }}%</div>
                <div class="sub">last ~2.5 trading days</div>
              </div>
            </div>
          </div>

          <div class="analysis-section">
            <h3>Why it fell</h3>
            {% if h.why_it_fell_html %}
              <div class="body">{{ h.why_it_fell_html|safe }}</div>
              {% if h.why_it_fell_citations %}
                <div class="citations">
                  <strong>Sources:</strong>
                  {% for c in h.why_it_fell_citations %}
                    <a href="{{ c.url }}" target="_blank" rel="noopener noreferrer">{{ c.title or c.url }}</a>
                  {% endfor %}
                </div>
              {% endif %}
            {% else %}
              <div class="analysis-skipped">{{ (h.why_it_fell_skip_reason or "Analysis not run.")|safe }}</div>
            {% endif %}
          </div>

          <div class="analysis-section">
            <h3>Deep dive</h3>
            {% if h.deep_dive_html %}
              <div class="body">{{ h.deep_dive_html|safe }}</div>
            {% else %}
              <div class="analysis-skipped">{{ (h.deep_dive_skip_reason or "Analysis not run.")|safe }}</div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </section>
  {% else %}
    <section>
      <h2>Oversold signals <span class="count">0</span></h2>
      <div class="empty-state">
        <div class="emoji-free-mark">No hits</div>
        <div>None of the {{ universe_size }} tracked tickers closed below RSI {{ oversold_threshold }} on the latest 4h bar.</div>
      </div>
    </section>
  {% endif %}

  {% if watch %}
    <section>
      <h2>Approaching oversold <span class="count buy-light">{{ watch|length }}</span></h2>
      <div class="watch-grid">
        {% for w in watch %}
          <div class="watch-card approaching-oversold">
            <div class="lhs">
              <div class="ticker">{{ w.ticker }}</div>
              <div class="company">{{ w.company }}</div>
            </div>
            <div class="rhs">
              <div class="rsi-val">{{ "%.1f"|format(w.rsi) }}</div>
              <div class="price">${{ "%.2f"|format(w.price) }}</div>
            </div>
          </div>
        {% endfor %}
      </div>
    </section>
  {% endif %}

  <section class="side-by-side">
    <div class="col">
      <h2>Overbought signals
        {% if overbought_hits %}
          <span class="count sell">{{ overbought_hits|length }}</span>
        {% else %}
          <span class="count">0</span>
        {% endif %}
      </h2>
      {% if overbought_hits %}
        <div class="ob-grid">
          {% for o in overbought_hits %}
            <div class="ob-card">
              <div class="lhs">
                <div class="ticker">{{ o.ticker }}</div>
                <div class="company">{{ o.company }}</div>
                <div class="sector-tag">{{ o.sector }}</div>
              </div>
              <div class="rhs">
                <div class="rsi-val">{{ "%.2f"|format(o.rsi) }}</div>
                <div class="price">${{ "%.2f"|format(o.price) }}</div>
                <div class="sub {% if o.move_5bar_pct >= 0 %}move-pos{% endif %}">{{ "%+.1f"|format(o.move_5bar_pct) }}% / 5 bar</div>
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="empty-state-compact">
          No tickers above RSI {{ overbought_threshold }} on the latest 4h bar.
        </div>
      {% endif %}
    </div>

    <div class="col">
      <h2>Approaching overbought
        {% if overbought_watch %}
          <span class="count sell-light">{{ overbought_watch|length }}</span>
        {% else %}
          <span class="count">0</span>
        {% endif %}
      </h2>
      {% if overbought_watch %}
        <div class="watch-grid">
          {% for w in overbought_watch %}
            <div class="watch-card approaching-overbought">
              <div class="lhs">
                <div class="ticker">{{ w.ticker }}</div>
                <div class="company">{{ w.company }}</div>
              </div>
              <div class="rhs">
                <div class="rsi-val">{{ "%.1f"|format(w.rsi) }}</div>
                <div class="price">${{ "%.2f"|format(w.price) }}</div>
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="empty-state-compact">
          No tickers between RSI {{ approaching_overbought_threshold }} – {{ overbought_threshold }}.
        </div>
      {% endif %}
    </div>
  </section>

  <section>
    <h2>Full scan <span class="count">{{ rows|length }}</span></h2>
    <details class="full-scan" {% if not hits %}open{% endif %}>
      <summary>
        Show all {{ rows|length }} tickers
        <button class="toggle-fund-btn" onclick="toggleFundamentals(event, this)">+ Fundamentals</button>
      </summary>
      <div class="scan-search">
        <input type="text" id="scan-search-input" placeholder="Filter by ticker, company, or sector..." autocomplete="off" spellcheck="false">
        <span class="visible-count" id="scan-visible-count">{{ rows|length }} of {{ rows|length }}</span>
      </div>
      <table id="scan-table">
        <thead>
          <tr>
            <th class="sortable" data-sort-kind="text" data-col-idx="0">Ticker<span class="sort-arrow">↕</span></th>
            <th class="sortable" data-sort-kind="text" data-col-idx="1">Company<span class="sort-arrow">↕</span></th>
            <th class="sortable" data-sort-kind="text" data-col-idx="2">Sector<span class="sort-arrow">↕</span></th>
            <th class="numeric sortable" data-sort-kind="numeric" data-col-idx="3">Price<span class="sort-arrow">↕</span></th>
            <th class="numeric sortable" data-sort-kind="numeric" data-col-idx="4">Bar change<span class="sort-arrow">↕</span></th>
            <th class="numeric sortable" data-sort-kind="numeric" data-col-idx="5" title="14-period Wilder RSI on 4h bars — uses the in-progress bar when one is open">RSI(14)<span class="sort-arrow">↕</span></th>
            <th class="fund-col numeric sortable" data-sort-kind="numeric" data-col-idx="6">Mkt Cap<span class="sort-arrow">↕</span></th>
            <th class="fund-col numeric sortable" data-sort-kind="numeric" data-col-idx="7">P/E<span class="sort-arrow">↕</span></th>
            <th class="fund-col numeric sortable" data-sort-kind="numeric" data-col-idx="8">PEG<span class="sort-arrow">↕</span></th>
            <th class="fund-col numeric sortable" data-sort-kind="numeric" data-col-idx="9">Beta<span class="sort-arrow">↕</span></th>
          </tr>
        </thead>
        <tbody>
          {% for r in rows %}
            <tr class="{% if r.status == 'oversold' %}row-oversold{% elif r.status == 'watch' %}row-watch{% elif r.status == 'overbought' %}row-overbought{% elif r.status == 'watch_overbought' %}row-watch-overbought{% elif r.status == 'error' %}row-error{% endif %}" data-search="{{ r.ticker|lower }} {{ r.company|lower }} {{ r.sector|lower }}">
              <td class="ticker">{{ r.ticker }}</td>
              <td>{{ r.company }}</td>
              <td class="sector">{{ r.sector }}</td>
              <td class="numeric" data-sort="{{ r.price if r.price is not none else '' }}">{% if r.price is not none %}${{ "%.2f"|format(r.price) }}{% else %}—{% endif %}</td>
              <td class="numeric {% if r.bar_change_pct is not none and r.bar_change_pct >= 0 %}change-pos{% elif r.bar_change_pct is not none %}change-neg{% endif %}" data-sort="{{ r.bar_change_pct if r.bar_change_pct is not none else '' }}">
                {% if r.bar_change_pct is not none %}{{ "%+.2f"|format(r.bar_change_pct) }}%{% else %}—{% endif %}
              </td>
              <td class="numeric" data-sort="{{ r.rsi if r.rsi is not none else '' }}">
                {% if r.rsi is not none %}
                  <span class="rsi-cell {% if r.status == 'oversold' %}oversold{% elif r.status == 'watch' %}watch{% elif r.status == 'overbought' %}overbought{% elif r.status == 'watch_overbought' %}watch-overbought{% endif %}">{{ "%.2f"|format(r.rsi) }}</span>
                {% else %}—{% endif %}
              </td>
              <td class="fund-col numeric" data-sort="{{ r.market_cap if r.market_cap is not none else '' }}">{{ r.market_cap | fmt_market_cap }}</td>
              <td class="fund-col numeric" data-sort="{{ r.pe if r.pe is not none else '' }}">{% if r.pe is not none %}{{ "%.1f"|format(r.pe) }}{% else %}—{% endif %}</td>
              <td class="fund-col numeric" data-sort="{{ r.peg if r.peg is not none else '' }}">{% if r.peg is not none %}{{ "%.2f"|format(r.peg) }}{% else %}—{% endif %}</td>
              <td class="fund-col numeric" data-sort="{{ r.beta if r.beta is not none else '' }}">{% if r.beta is not none %}{{ "%.2f"|format(r.beta) }}{% else %}—{% endif %}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
      <div class="empty-search" id="scan-empty">No tickers match the filter.</div>
    </details>
    <script>
      function toggleFundamentals(event, btn) {
        event.preventDefault();
        event.stopPropagation();
        var table = btn.closest('details').querySelector('table');
        var show = table.classList.toggle('show-fundamentals');
        btn.textContent = show ? '− Fundamentals' : '+ Fundamentals';
      }
      (function() {
        var input = document.getElementById('scan-search-input');
        var table = document.getElementById('scan-table');
        var empty = document.getElementById('scan-empty');
        var counter = document.getElementById('scan-visible-count');
        if (!input || !table) return;
        var rows = table.querySelectorAll('tbody tr');
        var total = rows.length;
        input.addEventListener('input', function(e) {
          var q = e.target.value.toLowerCase().trim();
          var visible = 0;
          rows.forEach(function(row) {
            var hay = row.getAttribute('data-search') || '';
            var match = !q || hay.indexOf(q) !== -1;
            row.style.display = match ? '' : 'none';
            if (match) visible++;
          });
          counter.textContent = visible + ' of ' + total;
          if (empty) empty.style.display = visible === 0 ? 'block' : 'none';
          if (empty && visible === 0) {
            table.style.borderBottomLeftRadius = '0';
            table.style.borderBottomRightRadius = '0';
          } else if (table) {
            table.style.borderBottomLeftRadius = '';
            table.style.borderBottomRightRadius = '';
          }
        });

        // Column sorting
        var ARROW_UNSORTED = '↕', ARROW_ASC = '▲', ARROW_DESC = '▼';
        var sortState = { col: null, dir: null };
        var headers = table.querySelectorAll('thead th.sortable');
        var tbody = table.querySelector('tbody');

        function applySort() {
          var rs = Array.from(tbody.querySelectorAll('tr'));
          if (sortState.col === null) return;
          var idx = sortState.col.idx;
          var kind = sortState.col.kind;
          var dir = sortState.dir;
          rs.sort(function(a, b) {
            var ca = a.cells[idx], cb = b.cells[idx];
            if (kind === 'numeric') {
              var ra = ca.getAttribute('data-sort');
              var rb = cb.getAttribute('data-sort');
              var va = (ra === null || ra === '') ? NaN : parseFloat(ra);
              var vb = (rb === null || rb === '') ? NaN : parseFloat(rb);
              var aNaN = isNaN(va), bNaN = isNaN(vb);
              // Always push missing values to the bottom regardless of direction
              if (aNaN && bNaN) return 0;
              if (aNaN) return 1;
              if (bNaN) return -1;
              return dir === 'asc' ? va - vb : vb - va;
            } else {
              var sa = ca.textContent.trim().toLowerCase();
              var sb = cb.textContent.trim().toLowerCase();
              if (sa === sb) return 0;
              return dir === 'asc' ? (sa < sb ? -1 : 1) : (sa > sb ? -1 : 1);
            }
          });
          rs.forEach(function(r) { tbody.appendChild(r); });
        }

        headers.forEach(function(th) {
          th.addEventListener('click', function() {
            var idx = parseInt(th.getAttribute('data-col-idx'), 10);
            var kind = th.getAttribute('data-sort-kind');
            if (sortState.col && sortState.col.idx === idx) {
              sortState.dir = sortState.dir === 'asc' ? 'desc' : 'asc';
            } else {
              sortState.col = { idx: idx, kind: kind, th: th };
              // Sensible default: numeric desc (largest first), text asc (A→Z)
              sortState.dir = kind === 'numeric' ? 'desc' : 'asc';
            }
            headers.forEach(function(h) {
              h.classList.remove('sort-asc', 'sort-desc');
              var arr = h.querySelector('.sort-arrow');
              if (arr) arr.textContent = ARROW_UNSORTED;
            });
            th.classList.add(sortState.dir === 'asc' ? 'sort-asc' : 'sort-desc');
            var arrow = th.querySelector('.sort-arrow');
            if (arrow) arrow.textContent = sortState.dir === 'asc' ? ARROW_ASC : ARROW_DESC;
            applySort();
          });
        });
      })();
    </script>
  </section>

  <footer class="page">
    <div>
      Generated {{ run_ts_iso }} &middot; Wilder RSI({{ rsi_period }}) on 4h closed bars &middot; TradingView convention (9:30 / 13:30 ET)
    </div>
    <div>
      Analysis model: <span class="mono">{{ analysis_model or "—" }}</span> &middot; Data: yfinance
    </div>
  </footer>

</div>
</body>
</html>
